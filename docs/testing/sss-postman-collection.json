    {
      "name": "Stablecoin Management",
      "item": [
        {
          "name": "POST /create-stablecoin - Create New Stablecoin",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"preset\": \"sss2\",\n    \"name\": \"USD Black\",\n    \"symbol\": \"USDb\",\n    \"decimals\": 6,\n    \"uri\": \"https://pastebin.com/raw/SjTJzhvy\",\n    \"extensions\": {\n        \"permanentDelegate\": true,\n        \"transferHook\": true,\n        \"defaultFrozen\": false,\n        \"confidential\": false\n    },\n    \"roles\": {\n        \"minter\": \"Optional_PubKey\",\n        \"burner\": \"Optional_PubKey\",\n        \"pauser\": \"Optional_PubKey\",\n        \"blacklister\": \"Optional_PubKey\",\n        \"seizer\": \"Optional_PubKey\"\n    },\n    \"oracle\": {\n        \"enabled\": false\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/create-stablecoin",
            "description": "Creates a new stablecoin and returns the database record along with the on-chain transaction signature."
          },
          "response": []
        },
        {
          "name": "GET /list-stablecoins - List All Stablecoins",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/list-stablecoins?limit=50&offset=0"
          },
          "response": []
        },
        {
          "name": "GET /get-stablecoin/:mintAddress - Get Specific Stablecoin",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/get-stablecoin/:mintAddress",
            "description": "Returns detailed information about a stablecoin, including database record and real-time on-chain data (supply, roles, extensions)."
          },
          "response": []
        },
        {
          "name": "GET /get-stablecoin/:mintAddress/history - Get Transaction History",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/get-stablecoin/:mintAddress/history",
            "description": "Returns recent mint and burn requests for the specified stablecoin."
          },
          "response": []
        }
      ]
