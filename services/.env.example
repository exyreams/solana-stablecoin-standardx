# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com

# Stablecoin mint address (Optional, set after first deploy)
STABLECOIN_MINT=

# Metaplex metadata PDA (set after initializing metadata)
METADATA_PDA=

# Authority keypair as JSON array, e.g. [1,2,3,...,64]
AUTHORITY_SECRET_KEY=

# Redis (for BullMQ queues)
REDIS_URL=redis://:your-redis-password@localhost:6379
REDIS_PASSWORD=your-redis-password

# SQLite database (stored at services/db/dev.db)
DATABASE_URL=file:./db/dev.db

# SSS Oracle program ID (optional, uses IDL default if not set)
SSS_TOKEN_PROGRAM_ID=

# HTTP port
PORT=3000

# Logging level (trace, debug, info, warn, error)
LOG_LEVEL=info

# CORS allowed origins (comma-separated list)
# Example: http://localhost:5173,http://localhost:5174,https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Authentication
# Secret key for JWT signing
JWT_SECRET=your-super-secret-jwt-key
# Secret token for admin registration
REGISTRATION_SECRET=your-registration-secret-token
