# Solana Stablecoin Standard CLI Configuration
# Copy this file to .env and update with your values

# Solana RPC URL
# Options: 
#   - Devnet: https://api.devnet.solana.com
#   - Mainnet: https://api.mainnet-beta.solana.com
#   - Localnet: http://localhost:8899
#   - Custom RPC: https://your-rpc-provider.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Path to your Solana keypair file
# Default: ~/.config/solana/id.json
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# Your stablecoin mint address (set after running 'sss-token init')
# Example: 2qfDMPMeK6SmyK9DPi8Pe8y1rjHJZFASDREw5K2frVag
STABLECOIN_MINT=

# Optional: Commitment level for transactions
# Options: processed, confirmed, finalized
# Default: confirmed
SOLANA_COMMITMENT=confirmed

# Optional: WebSocket URL (auto-computed from RPC URL if not set)
# SOLANA_WS_URL=wss://api.devnet.solana.com
