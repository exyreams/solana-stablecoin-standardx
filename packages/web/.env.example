# Solana RPC Endpoint
# For mainnet-beta, use: https://api.mainnet-beta.solana.com
# For devnet, use: https://api.devnet.solana.com
# For localnet, use: http://localhost:8899
# Or use a custom RPC provider like Helius, QuickNode, etc.
VITE_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Network (mainnet-beta, devnet, testnet, localnet)
VITE_NETWORK=devnet

